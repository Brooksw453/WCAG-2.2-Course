# Supabase - Get these from your Supabase project dashboard:
# Settings > API > Project URL and Project API keys (anon/public)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase Service Role Key (for SSO user creation)
# Settings > API > Project API keys (service_role)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Anthropic Claude API Key
# Get from https://console.anthropic.com/
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# SSO - Dashboard Integration
# Must match the DASHBOARD_SSO_SECRET in the Course Dashboard
DASHBOARD_SSO_SECRET=your-shared-sso-secret-here

# Dashboard URL (where users go for signup/enrollment/payments)
DASHBOARD_URL=https://courses.esdesigns.org

# This course's slug on the dashboard (used for redirect URLs)
COURSE_SLUG=introduction-to-business
